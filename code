├── /* Reset di base */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

/* Corpo della pagina */
body {
    font-family: Arial, sans-serif;
    background-color: #f4f4f4;
    color: #333;
}

/* Header e menu */
header {
    background-color: #333;
    color: white;
    padding: 10px;
    text-align: center;
}

.menu-icon {
    font-size: 30px;
    cursor: pointer;
}

nav {
    display: none;
    background-color: #444;
    position: absolute;
    top: 50px;
    right: 10px;
    width: 200px;
    border-radius: 5px;
}

nav ul {
    list-style: none;
    padding: 10px;
}

nav ul li {
    margin: 10px 0;
}

nav ul li a {
    color: white;
    text-decoration: none;
}

/* Media query per dispositivi mobili */
@media (max-width: 768px) {
    nav {
        display: block;
    }
}
└── function toggleMenu() {
    const menu = document.getElementById('menu');
    menu.classList.toggle('hidden');
}
